{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Meeting Recorder",
  "version": "2.1.0",
  "identifier": "com.joshuarodriguez.meeting-recorder",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Meeting Recorder",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Joshua Rodriguez",
    "copyright": "Copyright 2026 Joshua Rodriguez",
    "category": "Productivity",
    "shortDescription": "AI-powered meeting recorder, transcription, and summarizer",
    "longDescription": "Record meetings, transcribe with Whisper, identify speakers with Pyannote, and extract summaries, action items, requirements, and decisions using Claude.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../backend-bundle.zip": "backend-bundle.zip"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
